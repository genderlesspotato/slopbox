# Copy to .env and fill in values. Never commit .env.

# ---------------------------------------------------------------------------
# Single-cluster mode (legacy / interactive use)
# ---------------------------------------------------------------------------
# Provide ES_HOST or ES_CLOUD_ID (not both).
ES_HOST=https://localhost:9200
# ES_CLOUD_ID=

# Provide ES_API_KEY or ES_USERNAME + ES_PASSWORD. API key takes precedence.
ES_API_KEY=
# ES_USERNAME=elastic
# ES_PASSWORD=

# ---------------------------------------------------------------------------
# Vault (required for multi-cluster mode via clusters.yaml)
# ---------------------------------------------------------------------------
# Vault server URL.
VAULT_ADDR=https://vault.example.com

# Token auth — set after running: vault login
# In CI pipelines this is populated by the Vault OIDC GitHub Actions step.
# Not required when running inside a Kubernetes pod (k8s SA auth is used).
# VAULT_TOKEN=

# Vault k8s auth role name used by Temporal workers and other in-cluster tools.
# Default: slopbox
# VAULT_ROLE=slopbox

# KV secrets engine mount name. Default: secret
# VAULT_KV_MOUNT=secret

# KV engine version: 1 or 2. Default: 2
# VAULT_KV_VERSION=2

# ---------------------------------------------------------------------------
# Kubernetes (for k8s tools — auth strategy TBD, see CLAUDE.md)
# ---------------------------------------------------------------------------
# KUBECONFIG=~/.kube/config
# K8S_CONTEXT=
# K8S_NAMESPACE=
